import java.util.Locale;

/*
Enunciado:
Crie um programa em Java que identifique e exiba o idioma
configurado na máquina do usuário. O programa deve mostrar
no console qual é o idioma padrão do sistema operacional.

Exemplo de saída:
A maquina esta no idioma:
pt_BR
*/

public class IdiomaSistema {
    public static void main(String[] args) {
        Locale idioma = Locale.getDefault();

        System.out.println("A maquina esta no idioma: ");
        System.out.println(idioma);
    }
}
